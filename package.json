{
  "name": "rolodexian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cross-env NODE_ENV=development PORT=4000 node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "check": "tsc --noEmit",
    "seed": "node scripts/seed-demo.js",
    "seed:clear": "node scripts/seed-demo.js --clear"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-3d": "^1.29.1",
    "react-router-dom": "^6.28.1",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.185.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
